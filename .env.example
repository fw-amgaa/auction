# ---- Database (Postgres) ----
DATABASE_URL="postgres://auction:auction@localhost:5433/auction"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- Auth (better-auth) ----
# generate: openssl rand -base64 32
AUTH_SECRET="change-me-in-prod"
# Public origin better-auth uses to build all callback/redirect URLs. MUST be
# the externally reachable URL (e.g. https://anav.mn in prod) — never the
# container bind host — otherwise links point at 0.0.0.0:3000. Falls back to
# APP_URL if unset.
BETTER_AUTH_URL="http://localhost:3000"

# ---- WebSocket bid service ----
# shared secret used by web to sign short-lived WS tickets, verified by apps/bid
WS_TICKET_SECRET="change-me-in-prod"
BID_WS_PORT="8080"
# public URL the browser connects to (Caddy proxies /ws -> bid service in prod)
NEXT_PUBLIC_WS_URL="ws://localhost:8080"

# ---- S3 (KYC docs + lot images) ----
S3_BUCKET=""
S3_REGION="ap-southeast-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ---- Email (Resend) ----
# When RESEND_API_KEY and EMAIL_FROM are both set, password emails send via
# Resend (the EMAIL_FROM domain must be verified in the Resend dashboard).
# Leave either empty in dev to instead log the set-password / reset link to
# the server console.
RESEND_API_KEY=""
EMAIL_FROM="noreply@example.mn"
# Base URL used to build links inside emails.
APP_URL="http://localhost:3000"

# ---- Feature flags (resolved decisions) ----
# SMS/OTP off at launch; flip on when a Mongolian SMS gateway is wired
SMS_ENABLED="false"
OTP_ENABLED="false"
